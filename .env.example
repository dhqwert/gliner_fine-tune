# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Dùng để gọi GPT-4o-mini tự động annotate dữ liệu NER cho GLiNER fine-tune
# Lấy key tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Paths ───────────────────────────────────────────────────────────────────
# Đường dẫn tương đối tính từ thư mục gliner-finetune/ hoặc tuyệt đối đều được

# for_train.json — file sample đã được tạo bởi sample_for_train.py (ưu tiên đọc)
FOR_TRAIN_FILE=./data/for_train.json

# Thư mục logs chứa standardized_jobs.json (chỉ dùng khi KHÔNG có for_train.json)
STD_LOGS_DIR=../standardization_job/logs

# File output train_dataset.json (kết quả annotate bởi GPT-4o-mini)
OUTPUT_FILE=./data/train_dataset.json

# ─── Concurrency ─────────────────────────────────────────────────────────────
# Số request GPT-4o-mini chạy song song (tăng nếu tier API cao, giảm nếu bị rate limit)
CONCURRENCY_LIMIT=20

# ─── Giới hạn số job theo provider (chỉ dùng trong fallback) ─────────────────
# Xóa dòng hoặc để trống để dùng giá trị mặc định
LIMIT_ITVIEC=1000
LIMIT_TOPCV=3000
LIMIT_TOPDEV=2500
LIMIT_MBBANK=1500
LIMIT_DEFAULT=500

# ─── Deployment API ──────────────────────────────────────────────────────────
# Có 2 cách deploy model:
# CÁCH 1: Dùng thư mục local (Volume Mount)
# Trỏ đường dẫn này vào thư mục mount Model. Mặc định: ./models/checkpoint-1400
GLINER_MODEL_PATH=

# CÁCH 2: Dùng MinIO (Auto-Pull)
# Điền thông tin MinIO và Tên thư mục model (Prefix). Code sẽ tự tải về máy và chạy.
MINIO_EXTERNAL_ENDPOINT=
MINIO_INTERNAL_ENDPOINT=
MINIO_USE_SSL=false
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=
GLINER_MINIO_PREFIX=
